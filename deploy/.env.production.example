# Copy to /opt/folio/.env on the VPS and fill in. Do NOT commit real secrets.

# Domains. The VPS-level reverse proxy uses these to route traffic and handle TLS.
APP_DOMAIN=folio.davidsbatista.com
API_DOMAIN=api.folio.davidsbatista.com
APP_URL=https://folio.davidsbatista.com

# GitHub Container Registry image owner. Use your GitHub username/org in lowercase.
GHCR_OWNER=your-github-owner-lowercase
IMAGE_TAG=latest

# Local-only ports consumed by the VPS-level reverse proxy.
WEB_BIND=127.0.0.1
WEB_PORT=13000
BACKEND_BIND=127.0.0.1
BACKEND_PORT=13080

# Postgres.
POSTGRES_DB=folio
POSTGRES_USER=folio
POSTGRES_PASSWORD=change_me_long_random

# App secrets.
# Generate with: openssl rand -base64 64
SESSION_SECRET=change_me_64_random_chars
# Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=change_me_base64_32_bytes

# Signup/admin behavior. Valid REGISTRATION_MODE values: open, invite_only, first_run_only.
REGISTRATION_MODE=invite_only
ADMIN_BOOTSTRAP_EMAIL=you@example.com

# WebAuthn/passkeys.
WEBAUTHN_RP_ID=folio.davidsbatista.com
WEBAUTHN_RP_NAME=Folio
WEBAUTHN_RP_ORIGIN=https://folio.davidsbatista.com

# Security windows. Go duration syntax, e.g. 5m, 10m, 1h.
MFA_CHALLENGE_TTL=5m
REAUTH_WINDOW=5m

# Email delivery. Leave RESEND_API_KEY empty to log email instead of sending it.
RESEND_API_KEY=
EMAIL_FROM=Folio <noreply@folio.davidsbatista.com>

# Bank provider integration.
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Observability.
SENTRY_DSN=
