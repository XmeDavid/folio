{{ define "layout" -}}
<!doctype html>
<html>
  <head><meta charset="utf-8"><title>{{ .Subject }}</title></head>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 560px; margin: 40px auto; color: #222;">
    <h1 style="font-size: 20px; margin: 0 0 24px;">Folio</h1>
    {{ template "content" . }}
    <hr style="border: none; border-top: 1px solid #eee; margin: 32px 0;">
    <p style="font-size: 12px; color: #888;">
      You received this email because someone used your address at Folio.
      If that wasn't you, you can safely ignore this message.
    </p>
  </body>
</html>
{{- end }}
