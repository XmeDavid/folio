# ──────────────────────────────────────────────────────────────
# Folio – environment variables (example)
# Copy to .env for local dev; never commit .env.
# ──────────────────────────────────────────────────────────────

# ─── Core ─────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=folio
POSTGRES_USER=folio
POSTGRES_PASSWORD=folio_dev_password
DATABASE_URL=postgres://folio:folio_dev_password@localhost:5432/folio?sslmode=disable

# ─── Backend ──────────────────────────────────────────────────
HTTP_ADDR=:8080
LOG_LEVEL=debug

# 32-byte key (base64) used to encrypt provider tokens at rest.
# Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes

# Session cookie signing key (>=32 bytes).
# Generate with: openssl rand -base64 64
SESSION_SECRET=CHANGE_ME_random_long_string

# ─── Auth / WebAuthn ──────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Folio
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# ─── GoCardless Bank Account Data ─────────────────────────────
# https://bankaccountdata.gocardless.com/user-secrets/
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# ─── IBKR Flex ────────────────────────────────────────────────
# Per-user: tokens are stored encrypted in DB.
# This is only used for out-of-band testing.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
