# ──────────────────────────────────────────────────────────────
# Folio – environment variables (example)
# Copy to .env for local dev; never commit .env.
# ──────────────────────────────────────────────────────────────

# ─── Core ─────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# ─── Postgres ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=folio
POSTGRES_USER=folio
POSTGRES_PASSWORD=folio_dev_password
DATABASE_URL=postgres://folio:folio_dev_password@localhost:5432/folio?sslmode=disable

# ─── Backend ──────────────────────────────────────────────────
HTTP_ADDR=:8080
LOG_LEVEL=debug

# 32-byte key (base64) used to encrypt provider tokens at rest.
# This value is dev-only. For real deployments, generate with:
#   openssl rand -base64 32
SECRET_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# Session cookie signing key (>=32 bytes). Dev-only placeholder.
# For real deployments, generate with:
#   openssl rand -base64 64
SESSION_SECRET=CHANGE_ME_generate_random_32_plus_char_string

# ─── Auth / WebAuthn ──────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Folio
WEBAUTHN_RP_ORIGINS=http://localhost:3000
MFA_CHALLENGE_TTL=5m
REAUTH_WINDOW=5m

# Admin bootstrap: the first signup whose lowercased email matches this value
# is auto-granted is_admin=true. Leave unset unless bootstrapping a self-hosted
# instance; prefer the folio-admin CLI afterwards.
ADMIN_BOOTSTRAP_EMAIL=

# ─── Transactional Email ─────────────────────────────────────
# Empty RESEND_API_KEY uses the in-process LogMailer in dev.
RESEND_API_KEY=
EMAIL_FROM=Folio <onboarding@localhost>

# ─── GoCardless Bank Account Data ─────────────────────────────
# https://bankaccountdata.gocardless.com/user-secrets/
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# ─── IBKR Flex ────────────────────────────────────────────────
# Per-user: tokens are stored encrypted in DB.
# This is only used for out-of-band testing.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ─── Observability ────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
